---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<header class="site-header" id="top">
		<div class="brand">Laura Sound Festival 40</div>

		<button
			class="menu-toggle"
			id="menuToggle"
			aria-expanded="false"
			aria-controls="mainNav"
			aria-label="Abrir menu"
		>
			<span></span>
			<span></span>
			<span></span>
		</button>

		<nav class="main-nav" id="mainNav">
			<a href="#programa">Programa</a>
			<a href="#como-llegar">Como llegar</a>
			<a href="#buses">Buses ida y vuelta</a>
			<a href="#horarios">Horarios</a>
			<a href="#confirmar">Confirmar asistencia</a>
		</nav>
	</header>

	<main>
		<section class="hero section" aria-labelledby="hero-title">
			<div class="hero-glow hero-glow-left" aria-hidden="true"></div>
			<div class="hero-glow hero-glow-right" aria-hidden="true"></div>

			<p class="eyebrow">5 Septiembre 2026 · Susinos del Páramo, Burgos</p>
			<h1 id="hero-title">Save the Date · Laura Sound Festival 40</h1>
			<p class="hero-copy">
				Una celebracion con sonido festivalero, buen rollo y mucha música.
			</p>
			<a class="cta" href="#confirmar">Confirmar asistencia</a>
		</section>

		<section class="section" id="programa">
			<h2>Programa</h2>
			<p>
				El dia estara organizado por tramos para que sea facil ubicarse. Los horarios
				exactos estan en la seccion de abajo.
			</p>
			<div class="grid cards-3">
				<article class="card">
					<h3>Mediodia</h3>
					<p>Arrancamos con llegada, bienvenida, vermut y charanga.</p>
					<p>Tambien tendremos tiempo de comer una buena paella.</p>
				</article>
				<article class="card">
					<h3>Tarde</h3>
					<p>Tiempo de mojitada y torneo de tuta para mantener el ambiente arriba.</p>
					<p>Calentaremos motores para los conciertos de la noche.</p>
				</article>
				<article class="card">
					<h3>Noche</h3>
					<p>Concierto Buskers21, cena y cierre musical con un concierto sorpresa.</p>
					<p>Un final de fiesta pensado para cantar y bailar hasta el ultimo tema.</p>
				</article>
			</div>
		</section>

		<section class="section" id="como-llegar">
			<h2>Como llegar</h2>
			<div class="card">
				<div>
					<p>
						El evento se celebra en <strong>Susinos del Páramo, Burgos</strong>. Puedes llegar
						en coche compartido o en los buses organizados.
					</p>
					<ul>
						<li>Punto de encuentro principal: por definir</li>
						<li>Aparcamiento: por definir</li>
						<li>Ubicacion exacta: Susinos del Páramo, Burgos</li>
					</ul>
					<a
						class="cta"
						href="https://www.google.com/maps/search/?api=1&query=Susinos+del+P%C3%A1ramo,+Burgos"
						target="_blank"
						rel="noopener noreferrer"
					>
						Abrir en Google Maps
					</a>
				</div>
			</div>
		</section>

		<section class="section" id="buses">
			<h2>Buses ida y vuelta</h2>
			<div class="grid cards-2">
				<article class="card">
					<h3>Bus de ida</h3>
					<p>Salida desde Burgos (Plaza de España).</p>
					<p>Hora estimada: 12:00</p>
				</article>
				<article class="card">
					<h3>Bus de vuelta</h3>
					<p>Regreso desde Susinos del Páramo, al finalizar la celebracion.</p>
					<p>Hora estimada: 00:00</p>
				</article>
			</div>
		</section>

		<section class="section" id="horarios">
			<h2>Horarios</h2>
			<div class="card">
				<ol class="timeline">
					<li><span>12:30</span> Llegada, bienvenida y vermut</li>
					<li><span>13:00</span> Charanga Sobrinos del Cid</li>
					<li><span>15:00</span> Paellada</li>
					<li><span>17:00</span> Mojitada</li>
					<li><span>18:00</span> Torneo de tuta</li>
					<li><span>20:00</span> Concierto Buskers21</li>
					<li><span>22:30</span> Cena</li>
					<li><span>23:30</span> Concierto sorpresa</li>
				</ol>
			</div>
		</section>

		<section class="section" id="confirmar">
			<h2>Confirmar asistencia</h2>
			<form class="card form" id="confirmForm" action="https://formspree.io/f/mdavjjkr" method="POST">
				<label for="nombre">Nombre</label>
				<input id="nombre" name="nombre" type="text" placeholder="Tu nombre" required />

				<label for="email">Email</label>
				<input id="email" name="email" type="email" placeholder="tu@email.com" required />

				<label for="asistencia">Asistencia</label>
				<select id="asistencia" name="asistencia" required>
					<option value="" selected disabled>Selecciona una opcion</option>
					<option value="si">Si, voy</option>
					<option value="no">No puedo ir</option>
					<option value="duda">Aun no lo se</option>
				</select>

				<label for="bus">Bus</label>
				<select id="bus" name="bus">
					<option value="ninguno" selected>No necesito bus</option>
					<option value="ida">Solo ida</option>
					<option value="vuelta">Solo vuelta</option>
					<option value="ida-vuelta">Ida y vuelta</option>
				</select>

				<button type="submit">Enviar</button>
				<p class="form-status" id="formStatus" role="status" aria-live="polite" hidden></p>
			</form>
		</section>
	</main>

	<footer class="site-footer">
		<p>Laura Sound Festival 40 · 5 Sept 2026</p>
	</footer>
</Layout>

<script>
	const menuToggle = document.getElementById('menuToggle');
	const mainNav = document.getElementById('mainNav');
	const navLinks = Array.from(document.querySelectorAll('.main-nav a'));
	const sections = navLinks
		.map((link) => link.getAttribute('href'))
		.filter((href): href is string => Boolean(href))
		.map((href) => document.querySelector(href))
		.filter((section): section is Element => section !== null);

	function closeMenu() {
		if (!mainNav?.classList.contains('is-open')) {
			return;
		}

		mainNav.classList.remove('is-open');
		menuToggle?.setAttribute('aria-expanded', 'false');
	}

	menuToggle?.addEventListener('click', () => {
		const isOpen = mainNav?.classList.toggle('is-open');
		menuToggle.setAttribute('aria-expanded', String(Boolean(isOpen)));
	});

	navLinks.forEach((link) => {
		link.addEventListener('click', () => {
			closeMenu();
		});
	});

	document.addEventListener('click', (event) => {
		const target = event.target;
		if (target instanceof Node && mainNav && menuToggle) {
			if (!mainNav.contains(target) && !menuToggle.contains(target)) {
				closeMenu();
			}
		}
	});

	window.addEventListener('resize', () => {
		if (window.innerWidth > 780) {
			mainNav?.classList.remove('is-open');
			menuToggle?.setAttribute('aria-expanded', 'false');
		}
	});

	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (!entry.isIntersecting) {
					return;
				}

				const activeId = `#${entry.target.id}`;
				navLinks.forEach((link) => {
					const isActive = link.getAttribute('href') === activeId;
					link.classList.toggle('active', isActive);
				});
			});
		},
		{
			rootMargin: '-35% 0px -55% 0px',
			threshold: 0.01,
		},
	);

	sections.forEach((section) => observer.observe(section));

	const confirmForm = document.getElementById('confirmForm');
	const formStatus = document.getElementById('formStatus');

	if (confirmForm instanceof HTMLFormElement && formStatus instanceof HTMLParagraphElement) {
		confirmForm.addEventListener('submit', async (event) => {
			event.preventDefault();

			const submitButton = confirmForm.querySelector('button[type="submit"]');
			if (!(submitButton instanceof HTMLButtonElement)) {
				return;
			}

			submitButton.disabled = true;
			submitButton.textContent = 'Enviando...';
			formStatus.hidden = false;
			formStatus.classList.remove('is-success', 'is-error');
			formStatus.textContent = 'Enviando formulario...';

			try {
				const response = await fetch(confirmForm.action, {
					method: 'POST',
					body: new FormData(confirmForm),
					headers: {
						Accept: 'application/json',
					},
				});

				if (response.ok) {
					formStatus.classList.add('is-success');
					formStatus.textContent = 'Gracias, tu confirmacion se ha enviado correctamente.';
					confirmForm.reset();
					return;
				}

				let errorMessage = 'No se pudo enviar el formulario. Intentalo de nuevo.';
				const payload = (await response.json().catch(() => null)) as
					| { errors?: Array<{ message?: string }> }
					| null;
				const firstError = payload?.errors?.[0]?.message;
				if (firstError) {
					errorMessage = firstError;
				}

				formStatus.classList.add('is-error');
				formStatus.textContent = errorMessage;
			} catch {
				formStatus.classList.add('is-error');
				formStatus.textContent = 'No hay conexion o hubo un error inesperado.';
			} finally {
				submitButton.disabled = false;
				submitButton.textContent = 'Enviar';
			}
		});
	}
</script>
